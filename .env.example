# NYC Trips Pipeline - Environment Variables Template
# IMPORTANTE: Copiar este archivo a .env y completar los valores
# NUNCA subir .env al repositorio (ya esta en .gitignore)

# PostgreSQL Connection (solo parametros de infraestructura)
# Las credenciales se configuran en Mage Secrets, NO aqui
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nyc_trips

# Mage Configuration (solo parametros de infraestructura)
# La conexion a la base de datos se configura en Mage Secrets

